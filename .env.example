# ─────────────────────────────────────────────
# CertMail — SMTP Configuration
# Rename this file to .env and fill in your details.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────

# Gmail example:
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_USERNAME=you@gmail.com
#   SMTP_PASSWORD=your-app-password   ← generate at myaccount.google.com/apppasswords
#
# Outlook / Office 365 example:
#   SMTP_HOST=smtp.office365.com
#   SMTP_PORT=587
#   SMTP_USERNAME=you@outlook.com
#   SMTP_PASSWORD=your-password
#
# Custom SMTP:
#   Set HOST, PORT, USERNAME, PASSWORD accordingly.

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=you@gmail.com
SMTP_PASSWORD=your-app-password-here

# Optional: override the "From" address shown to recipients.
# Defaults to SMTP_USERNAME if left blank.
SMTP_FROM_EMAIL=

# Enable STARTTLS (recommended). Set to false only for local dev.
SMTP_TLS=true

# Flask secret key — change this to a long random string in production.
SECRET_KEY=change-me-to-something-random

SMTP_ACTIVE=False
